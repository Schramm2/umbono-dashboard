# Umbono works without environment variables in deterministic demo mode.
# Add these values to enable live comparisons through any OpenAI-compatible API.

UMBONO_API_KEY=
UMBONO_BASE_URL=https://api.openai.com/v1
UMBONO_MODELS=your-model-id,another-model-id

# Production deployments stay demo-only unless this explicit opt-in is set.
# Before enabling it publicly, add authentication and rate limiting at your host or gateway.
UMBONO_ALLOW_LIVE_IN_PRODUCTION=false

# Optional safeguards and metadata.
UMBONO_MAX_TOKENS=800
UMBONO_REQUEST_TIMEOUT_MS=45000
UMBONO_APP_NAME=Umbono
# UMBONO_SITE_URL=http://localhost:3000

# Optional USD pricing per million tokens. Omit this to hide cost estimates.
# UMBONO_MODEL_PRICING={"your-model-id":{"input":0.4,"output":1.6}}

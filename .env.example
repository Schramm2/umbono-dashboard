# =========================================================================
# Umbono Environment Variables Configuration
# =========================================================================
# The dashboard supports two execution modes:
# 1. PORTFOLIO DEMO MODE (Default & Recommended for local showcase)
# 2. PRODUCTION INFRASTRUCTURE MODE (Connects to actual Supabase and LLMs)
# =========================================================================

# -------------------------------------------------------------------------
# 1. Portfolio Showcase / Demo Mode
# -------------------------------------------------------------------------
# Set to 'true' to run the app in a self-contained mock environment.
# Under Demo Mode:
# - Authentication is mocked with a simulated test user
# - Supabase database is bypassed for deterministic local storage
# - API calls to model providers are simulated locally with token/latency/cost estimates
# - NO paid API keys or database setup are required.
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# -------------------------------------------------------------------------
# 2. Production Mode (Requires Supabase & API Keys)
# -------------------------------------------------------------------------
# To connect to production infrastructure, set DEMO_MODE=false above and fill in:

# Supabase Configuration
# Retrieve these from: Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provider API Keys
# Only fill in keys for the providers you wish to query in production.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=


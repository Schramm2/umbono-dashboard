{
  "name": "umbono",
  "version": "0.2.0",
  "description": "An open-source studio for reproducible multi-model AI evaluations and human-scored comparisons.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Schramm2/umbono-dashboard.git"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "next dev --webpack",
    "demo": "UMBONO_FORCE_DEMO=true next dev --webpack",
    "start": "next start",
    "build": "next build --webpack",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.tests.json && node --test .test-dist/tests/*.test.js",
    "verify": "npm run test && npm run typecheck && npm run lint && npm run build",
    "export:showcase": "./scripts/export-showcase.sh"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.16",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  }
}
